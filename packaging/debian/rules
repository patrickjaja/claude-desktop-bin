#!/usr/bin/make -f
# NOTE: This debhelper file is NOT the live builder - .deb packages are produced
# by packaging/debian/build-deb.sh (dpkg-deb around the release tarball). Kept
# only for reference; its install mapping is aligned with the current tarball
# layout so it cannot mislead.

%:
	dh $@

override_dh_auto_install:
	# Install the official Claude Desktop tree verbatim (Electron runtime +
	# patched resources/app.asar + CU bridges); Electron auto-loads the
	# exe-adjacent resources/app.asar (OnlyLoadAppFromAsar fuse).
	install -d debian/claude-desktop/usr/lib/claude-desktop
	cp -r claude-desktop/* debian/claude-desktop/usr/lib/claude-desktop/

	# Install launcher (full launcher with Wayland/X11 detection, GPU fallback, etc.)
	install -d debian/claude-desktop/usr/bin
	install -m755 launcher/claude-desktop debian/claude-desktop/usr/bin/claude-desktop

	# Install desktop file (basename must match the live app_id "claude-desktop"
	# so native-Wayland WMs bind the dock icon; see issue #148)
	install -d debian/claude-desktop/usr/share/applications
	install -m644 debian/claude-desktop.desktop debian/claude-desktop/usr/share/applications/

	# Install icon
	install -d debian/claude-desktop/usr/share/icons/hicolor/256x256/apps
	install -m644 icons/claude-desktop.png debian/claude-desktop/usr/share/icons/hicolor/256x256/apps/

override_dh_strip:
	# Don't strip - Electron binaries don't like it

override_dh_shlibdeps:
	# Skip shlibdeps for Electron app
