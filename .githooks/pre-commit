#!/usr/bin/env bash
# Pre-commit hook: nim check + nph for patches, shellcheck for scripts

set -e

STAGED_NIM=$(git diff --cached --name-only --diff-filter=ACM -- 'patches/*.nim')
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM -- 'scripts/*.sh' 'packaging/rpm/*.sh')

if [ -n "$STAGED_NIM" ]; then
    if command -v nph &>/dev/null; then
        echo "Running nph format check on staged patches..."
        nph --check $STAGED_NIM
    fi
    if command -v nim &>/dev/null; then
        echo "Running nim check on staged patches..."
        for f in $STAGED_NIM; do
            nim check --hints:off "$f"
        done
    fi
fi

if [ -n "$STAGED_SH" ] && command -v shellcheck &>/dev/null; then
    echo "Running shellcheck on staged scripts..."
    shellcheck -S error $STAGED_SH
fi
