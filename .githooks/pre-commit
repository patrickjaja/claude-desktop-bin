#!/usr/bin/env bash
# Pre-commit hook: lint & format check for Python patches and shell scripts

set -e

# Check if any patches are staged
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- 'patches/*.py')
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM -- 'scripts/*.sh' 'packaging/rpm/*.sh')

if [ -n "$STAGED_PY" ] && command -v ruff &>/dev/null; then
    echo "Running ruff on staged patches..."
    ruff check $STAGED_PY
    ruff format --check $STAGED_PY
fi

if [ -n "$STAGED_SH" ] && command -v shellcheck &>/dev/null; then
    echo "Running shellcheck on staged scripts..."
    shellcheck -S error $STAGED_SH
fi
